# Database
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Cricket API (you can use cricketdata.org or any other cricket API)
CRICKET_API_KEY="your-api-key-here"
CRICKET_API_URL="https://api.cricapi.com/v1"


# ─── YouTube Live Streaming Service ───────────────────────────────────────────
# URL of the Hetzner/Railway streaming service (used by Next.js to trigger video jobs)
STREAMING_SERVICE_URL=http://localhost:3001

# YouTube OAuth2 credentials (from Google Cloud Console)
# Required for: auto-creating YouTube Live broadcasts + news video uploads
YOUTUBE_CHANNEL_ID=
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost
YOUTUBE_REFRESH_TOKEN=

# ─── Streaming service VPS only (.env inside streaming-service/ folder) ───────
# GOOGLE_TTS_API_KEY=   ← Indian accent TTS — optional, falls back to OpenAI TTS
#                         Get from: Google Cloud Console → Text-to-Speech API
# AUTO_STREAM=false
# AUTO_STREAM_POLL_SECONDS=60
# UPCOMING_STREAM_HOURS=1
# SKIP_MATCH_KEYS=
