# Database
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Cricket API (you can use cricketdata.org or any other cricket API)
CRICKET_API_KEY="your-api-key-here"
CRICKET_API_URL="https://api.cricapi.com/v1"


# ─── YouTube Live Streaming Service ───────────────────────────────────────────
# URL of the streaming service (Railway or local)
STREAMING_SERVICE_URL=http://localhost:3001

# YouTube OAuth2 credentials (from Google Cloud Console)
# Required for: auto-creating YouTube Live broadcasts
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost
YOUTUBE_REFRESH_TOKEN=

# Auto-stream: set to "true" to have the streaming service auto-detect live matches and go live
AUTO_STREAM=false
AUTO_STREAM_POLL_SECONDS=60
