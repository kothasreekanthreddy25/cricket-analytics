# Live match detection + score/ball-by-ball data now comes from
# crickettips.ai's own ticker + full-live endpoints (SportMonks-backed) via
# cricketData.js — no CricAPI or Roanuz key needed any more. Both are dead:
# Roanuz 403s on match endpoints, and CricAPI required its own paid key.

# OpenAI (GPT-4o commentary + TTS voice + video script generation)
# Fully optional — without this, the score overlay still streams; commentary
# falls back to a plain deterministic line instead of GPT-generated text.
OPENAI_API_KEY=your-openai-key-here

# Google Cloud TTS — Indian English accent (en-IN-Wavenet-D)
# Optional: if not set, falls back to OpenAI TTS automatically
# Get a key at: https://console.cloud.google.com → APIs & Services → Text-to-Speech API
GOOGLE_TTS_API_KEY=your-google-tts-api-key

# Pexels API — free cricket/stadium images for the separate news-video
# feature's backgrounds (unrelated to live streaming).
# Free at: https://www.pexels.com/api/  (200 req/hour, commercial use allowed, no attribution needed)
# Optional: falls back to gradient background if not set
PEXELS_API_KEY=your-pexels-api-key

# HeyGen API — AI avatar presenter for the separate news-video feature
# (unrelated to live streaming). Creator plan: $29/month.
# Get key at: https://app.heygen.com → Settings → API
# Optional: if not set, falls back to static DALL-E photo presenter + TTS audio
HEYGEN_API_KEY=your-heygen-api-key
HEYGEN_AVATAR_ID=Susan_expressive_20240820   # override with any avatar from your library
HEYGEN_VOICE_ID=e9a9dc96f1784d9a9ecff09f6e1fb04c  # override with any voice ID

# YouTube OAuth (for live streaming AND news video uploads).
# Reuse the SAME values already set in the main Next.js app's Railway env —
# a refresh token isn't tied to the redirect_uri that originally issued it,
# so no second OAuth flow is needed for the same channel.
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3006/api/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# Main CricketTips.ai app — this service's ONLY data source now:
#   /api/cricket/ticker                        — live match detection
#   /api/cricket/match/[matchKey]/full-live     — score, ball-by-ball, players
#   /api/stream/overlay-data                    — AI win-probability + Fantasy XI ticker
# All cache-only reads, safe to poll frequently.
CRICKETTIPS_API_URL=https://crickettips.ai

# Auto-stream settings
AUTO_STREAM=false
AUTO_STREAM_POLL_SECONDS=60
UPCOMING_STREAM_HOURS=1
SKIP_MATCH_KEYS=

# Service port
PORT=3001
