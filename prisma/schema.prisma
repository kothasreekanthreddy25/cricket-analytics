// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  TIPSTER
  ADMIN
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  phone         String?
  passwordHash  String?
  emailVerified Boolean    @default(false)
  image         String?
  role          String     @default("USER")
  plan          String     @default("free") // free, pro, elite
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  accounts      Account[]
  favorites     Favorite[]
  tips          Tip[]
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Cricket specific models
model Match {
  id          String     @id @default(cuid())
  matchId     String     @unique
  name        String
  matchType   String
  status      String
  venue       String
  date        DateTime
  dateTimeGMT DateTime
  teams       String[]
  teamInfo    Json
  score       Json?
  seriesId    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  favorites   Favorite[]
  tips        Tip[]
}

// Populated by lib/entity-crawler.ts (daily job, see lib/scheduler.ts Job #9)
// from real SportMonks data — powers the indexable /teams/[slug] pages.
model Team {
  id         String    @id @default(cuid())
  teamId     String    @unique
  slug       String    @unique
  name       String
  country    String
  flag       String?
  stats      Json?
  // Current roster, KnownPlayer[]-shaped ({id, name, role, isCaptain, isWicketkeeper})
  squad      Json?
  // Last time this team appeared in a currently-live/upcoming match — lets the
  // crawler distinguish "actively touring" teams from ones just sitting in the cache.
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// Populated by lib/entity-crawler.ts — powers the indexable /players/[slug]
// pages. stats is real SportMonks career data (same AggregatedCareerStats
// shape lib/ai-match-preview.ts already computes for Fantasy XI), never
// AI-generated.
model Player {
  id           String   @id @default(cuid())
  playerId     String   @unique
  slug         String   @unique
  name         String
  country      String
  role         String
  battingStyle String?
  bowlingStyle String?
  stats        Json?
  image        String?
  // SportMonks team IDs this player currently represents — for linking back
  // to /teams/[slug] from the player page.
  teamIds      String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Populated by lib/entity-crawler.ts — powers the indexable /venues/[slug]
// pages. stats is aggregated from every historical MatchAnalysis row at this
// venue (pitch tendency, avg first-innings score), not a fresh API call.
model Venue {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  city      String?
  country   String?
  stats     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, matchId])
}

enum TipConfidence {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

model Tip {
  id          String        @id @default(cuid())
  tipsterId   String
  matchId     String
  prediction  String
  odds        String?
  confidence  TipConfidence @default(MEDIUM)
  analysis    String?
  result      String?
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tipster     User          @relation(fields: [tipsterId], references: [id], onDelete: Cascade)
  match       Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([tipsterId])
  @@index([matchId])
  @@index([createdAt])
}

model MatchAnalysis {
  id              String   @id @default(cuid())
  matchKey        String
  teamA           String
  teamB           String
  winProbabilityA Float
  winProbabilityB Float
  confidence      String
  tips            Json
  playersToWatch  Json
  conditions      Json
  recentForm      Json
  reasoning       String
  rawData         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([matchKey])
}

model PredictionLead {
  id             String   @id @default(cuid())
  whatsapp       String?
  telegram       String?
  // Telegram bots can only message users who've sent /start to the bot —
  // there's no way to DM a raw @username. Set once the lead follows the
  // deep-link ("Activate on Telegram") shown after signup and the scheduler
  // picks up the resulting /start update. Null means reminders can't reach
  // them yet, no matter what they typed into the popup.
  telegramChatId String?
  name           String?
  source         String   @default("popup")
  createdAt      DateTime @default(now())

  // Weekly digest email opt-in. Separate from whatsapp/telegram since a lead
  // can subscribe to any combination of channels — emailOptIn is what the
  // weekly digest job actually checks, so an unsubscribe just flips this
  // rather than deleting the row (keeps whatsapp/telegram reminders intact).
  email      String?
  emailOptIn Boolean @default(false)

  @@index([createdAt])
  @@index([telegramChatId])
  @@index([emailOptIn])
}

// One row per (lead, match) reminder actually sent — the unique constraint
// is what prevents double-sending if the scheduler job runs again before
// the match starts.
model MatchReminder {
  id       String   @id @default(cuid())
  leadId   String
  matchKey String
  sentAt   DateTime @default(now())

  @@unique([leadId, matchKey])
  @@index([matchKey])
}

// One row per (match, kind) video ever attempted — the unique constraint is
// the dedupe that guarantees a match can never be turned into two videos of
// the same kind, no matter how often the daily job or manual trigger runs.
// Status flow: script_ready → render_triggered → uploaded (ids filled in by
// the render service callback in a later phase) | render_failed | script_failed
model VideoJob {
  id               String   @id @default(cuid())
  matchKey         String
  kind             String   @default("match_preview")
  teamA            String
  teamB            String
  tournament       String?
  matchDate        DateTime?
  title            String
  // Full structured script (scenes, narration, disclaimer) as produced by
  // generateVideoScript — the render service consumes this verbatim.
  script           Json
  status           String   @default("script_ready")
  error            String?
  youtubeVideoId   String?
  instagramMediaId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([matchKey, kind])
  @@index([status])
  @@index([createdAt])
}

// First-party click log for outbound bookmaker/affiliate links. UK/AU
// operators currently have no affiliate partner IDs of their own (unlike
// SA/NZ, whose URLs carry real tracking tags) — this exists so click volume
// is measurable regardless, and slots real affiliate IDs in later without
// losing the historical data.
model AffiliateClick {
  id             String   @id @default(cuid())
  bookmakerId    String
  bookmakerName  String
  country        String
  source         String // which component: sidebar, mobile-strip, banner
  matchKey       String?
  referer        String?
  createdAt      DateTime @default(now())

  @@index([bookmakerId])
  @@index([country])
  @@index([createdAt])
}

model Subscription {
  id                String   @id @default(cuid())
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  plan              String   // pro, elite
  amount            Int      // in paise
  currency          String   @default("INR")
  status            String   @default("created") // created, paid, failed
  name              String?
  email             String?
  phone             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// Manually-curated tournament/series/squad data — admin-entered, takes
// priority over the SportMonks "most recent match" heuristic in
// getPredictedXIs (see lib/manual-squads.ts), since SportMonks lineup data
// only reflects matches already played and can lag real squad announcements.
model Tournament {
  id        String   @id @default(cuid())
  name      String   // e.g. "India tour of England 2026"
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  series    Series[]
}

model Series {
  id           String   @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String   // e.g. "ODI Series"
  format       String   // "T20" | "T20I" | "ODI" | "TEST" — same convention as formatsMatch()
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  squads       SeriesSquad[]

  @@index([format])
  @@index([startDate, endDate])
}

// One row per team per series — players stored as KnownPlayer[]-shaped JSON
// ({id, name, role, isCaptain, isWicketkeeper}), matching the shape
// lib/ai-match-preview.ts's getPredictedXIs already returns everywhere else.
model SeriesSquad {
  id        String   @id @default(cuid())
  seriesId  String
  series    Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  teamName  String   // free text, matched by normalized-exact-match against match teamA/teamB
  players   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seriesId, teamName])
}
